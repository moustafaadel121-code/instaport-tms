# InstaPort TMS — Server Environment (fill with YOUR values)

# Super Admin credentials (never sent to browser)
SA_ORG=ip-master
SA_USER_ID=CHANGE_ME
SA_PIN=CHANGE_ME
SA_NAME=Super Admin

# Server
PORT=7434

# JWT — session tokens
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRY=8h

# Supabase (create free project at supabase.com, run supabase-schema.sql)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=

# 2FA — TOTP for Super Admin (optional)
SA_TOTP_SECRET=
SA_TOTP_ENABLED=false
